# Life-OS environment variables — copy to .env.local and fill in.
# Never commit .env.local (already gitignored).

# ─── Gemini ────────────────────────────────────────────────────────────────
# Used by /api/overseer, /api/patterns, /api/weekly-review, etc.
GEMINI_API_KEY=

# ─── Neon Postgres ─────────────────────────────────────────────────────────
# Pooled connection — used at runtime by the app via @neondatabase/serverless.
DATABASE_URL=postgresql://USER:PASS@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require
# Direct connection — used by drizzle-kit for migrations only.
DATABASE_URL_UNPOOLED=postgresql://USER:PASS@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require

# ─── Auth.js v5 (NextAuth) ────────────────────────────────────────────────
# `openssl rand -base64 32` to generate.
NEXTAUTH_SECRET=
# In production, set to your deployed URL (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App credentials — create two apps (one per environment).
# Authorization callback URL must be: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# ─── Google Health API (Fitbit / Pixel Watch sync) ────────────────────────
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=http://localhost:3000/api/fitbit/callback
