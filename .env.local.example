# Required: Google Gemini API key.
# Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Neon Postgres — either pooled or unpooled works at runtime. The
# pooled URL is preferred for serverless perf; the unpooled URL is
# required for drizzle-kit (DDL doesn't go through the pooler).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Auth.js v5 secret. Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET is the v4 name and still works.
NEXTAUTH_SECRET=
# AUTH_SECRET=

# Google SSO sign-in. Create at https://console.cloud.google.com →
# APIs & Services → Credentials → Create credentials → OAuth client ID
# → Web application. Authorized redirect URI must match exactly:
#   http://localhost:3000/api/auth/callback/google           (local dev)
#   https://<your-vercel-domain>/api/auth/callback/google    (production)
# At least one provider (Google OR Apple) must be configured.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Sign in with Apple. Optional second provider.
# 1. Apple Developer → Certificates, Identifiers & Profiles → Identifiers
#    → register a Services ID (e.g. com.hbrady.lifeos.signin). This is
#    the AUTH_APPLE_ID. Configure Sign In with Apple on it and add the
#    callback domain + return URL:
#      Domain:  <your-vercel-domain>
#      Return:  https://<your-vercel-domain>/api/auth/callback/apple
# 2. Keys tab → register a key with "Sign In with Apple" enabled,
#    download the .p8.
# 3. Generate the client secret JWT (valid for ≤6 months) and paste it as
#    AUTH_APPLE_SECRET. Quick snippet (run with node):
#      const jwt = require("jsonwebtoken");
#      console.log(jwt.sign({}, fs.readFileSync("AuthKey_XXX.p8"), {
#        algorithm: "ES256",
#        expiresIn: "180d",
#        issuer: "<TEAM_ID>",
#        audience: "https://appleid.apple.com",
#        subject: "<SERVICES_ID>",
#        keyid: "<KEY_ID>",
#      }));
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Google Health API (Fitbit / Pixel Watch / Google Fit health-data sync).
# Optional — if unset the Integrations card stays in "not connected"
# state. This is a SEPARATE OAuth client from the SSO one above: it
# requests health scopes and goes through PKCE.
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REDIRECT_URI=http://localhost:3000/api/google-health/callback

# Web Push (VAPID). Generate locally with:
#   npx web-push generate-vapid-keys
# Then paste below + add the same values to Vercel Production env. If
# any of the three is empty, push notifications are disabled cleanly
# (the Settings card hides, the cron 503s instead of throwing).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Vercel cron auth. Pick any long random string. Vercel automatically
# attaches `Authorization: Bearer ${CRON_SECRET}` to scheduled hits at
# the path listed in vercel.json. Without this set, /api/cron/* refuse
# all callers (no anonymous push-spam).
CRON_SECRET=
